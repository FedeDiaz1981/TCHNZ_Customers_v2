---
import ReconversionApp from "./ReconversionApp.jsx";

const {
  userEmail = "",
  locale = "es",
  backToAppsHref = "/clientes/aplicaciones",
  manualHref = "/clientes/aplicaciones/manual-usuario"
} = Astro.props;
---

<ReconversionApp
  client:load
  userEmail={userEmail}
  locale={locale}
  backToAppsHref={backToAppsHref}
  manualHref={manualHref}
/>
