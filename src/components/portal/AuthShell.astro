---
import LanguageSwitch from "./LanguageSwitch.astro";
import { getPublicHomeHref } from "../../lib/auth/public";
import type { CustomerLocale } from "../../lib/i18n/customers";

interface Props {
  eyebrow: string;
  heading: string;
  copy?: string;
  cardClass?: string;
  locale?: CustomerLocale;
  footerCopy?: string;
}

const {
  eyebrow,
  heading,
  copy = "",
  cardClass = "p-8",
  locale = "es",
  footerCopy = "Acceso a Technized Web Tools - Powered by BlatoRH"
} = Astro.props;

const homeHref = getPublicHomeHref();
---

<section class="portal-shell relative">
  <a
    href="/"
    class="absolute left-6 top-6 z-10 inline-flex items-center sm:left-10 sm:top-8"
    aria-label="Technized"
  >
    <img
      src="/customers/assets/brand/logo-technized-white.png"
      alt="Technized"
      class="h-auto w-[148px] sm:w-[172px]"
    />
  </a>

  <div class="absolute right-6 top-6 z-10 sm:right-10 sm:top-8">
    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={homeHref}
        class="portal-home-link inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white/80 transition hover:border-[#ff8c1a]/40 hover:bg-white/10 hover:text-white"
        aria-label={locale === "en" ? "Go to home" : "Volver a la home"}
      >
        <i class="fa-solid fa-house text-[#ff8c1a]" aria-hidden="true"></i>
        <span class="hidden sm:inline">{locale === "en" ? "Home" : "Home"}</span>
      </a>
      <LanguageSwitch locale={locale} redirectTo={`${Astro.url.pathname}${Astro.url.search}`} />
    </div>
  </div>

  <div class="mx-auto flex min-h-screen max-w-6xl items-center px-6 py-24 sm:px-8 sm:py-28 lg:px-6 lg:py-16">
    <div class="grid w-full gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="flex flex-col justify-center">
        <p class="portal-eyebrow mb-3">{eyebrow}</p>
        <h1 class="mb-4 text-4xl font-semibold leading-tight sm:text-5xl">{heading}</h1>
        {copy && <p class="portal-copy max-w-xl text-lg">{copy}</p>}
        <slot name="lead" />
      </div>

      <div class:list={["portal-panel portal-panel--warm rounded-[32px]", cardClass]}>
        <slot />
      </div>
    </div>
  </div>

  <p class="absolute inset-x-6 bottom-5 z-10 text-center text-[11px] font-medium uppercase tracking-[0.18em] text-white/45 sm:bottom-7 sm:text-xs">
    {footerCopy}
  </p>
</section>
