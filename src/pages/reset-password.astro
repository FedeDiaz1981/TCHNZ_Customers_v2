---
import AuthShell from "../components/portal/AuthShell.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCustomerLocale, getCustomerUi } from "../lib/i18n/customers";
import { withPortalBasePath } from "../lib/portal/base-path";

const error = Astro.url.searchParams.get("error");
const message = Astro.url.searchParams.get("message");
const user = Astro.locals.user;
const locale = getCustomerLocale(Astro.url, Astro.cookies);
const ui = getCustomerUi(locale).resetPassword;
---

<BaseLayout title={ui.title} description={ui.description} lang={locale}>
  <AuthShell
    eyebrow={ui.eyebrow}
    heading={ui.heading}
    copy={ui.copy}
    locale={locale}
    footerCopy={getCustomerUi(locale).authShell.footer}
  >
    <div class="mb-8">
      <p class="portal-eyebrow text-sm">{ui.overline}</p>
      <h2 class="mt-2 text-3xl font-semibold">{ui.cardHeading}</h2>
      <p class="portal-copy mt-2 text-sm">
        {user
          ? ui.readyCopy
          : ui.invalidCopy}
      </p>
    </div>

    {error && (
      <div class="mb-6 rounded-2xl border border-red-400/25 bg-red-500/10 px-4 py-3 text-sm text-red-100">
        {error}
      </div>
    )}

    {message && (
      <div class="mb-6 rounded-2xl border border-emerald-400/25 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-50">
        {message}
      </div>
    )}

    {
      user ? (
        <>
          <p class="mb-6 text-sm text-white/60">
            {ui.restoringAccess} <span class="text-white/85">{user.email}</span>
          </p>

          <form action={withPortalBasePath("/api/auth/reset-password")} method="POST" class="space-y-5">
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">{ui.newPassword}</span>
              <input
                type="password"
                name="password"
                autocomplete="new-password"
                required
                minlength="8"
                class="portal-input w-full rounded-2xl px-4 py-3"
                placeholder={ui.newPasswordPlaceholder}
              />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">{ui.confirmPassword}</span>
              <input
                type="password"
                name="confirmPassword"
                autocomplete="new-password"
                required
                minlength="8"
                class="portal-input w-full rounded-2xl px-4 py-3"
                placeholder={ui.confirmPasswordPlaceholder}
              />
            </label>

            <button
              type="submit"
              class="portal-submit inline-flex w-full items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em]"
            >
              {ui.submit}
            </button>
          </form>
        </>
      ) : (
        <div class="space-y-4">
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-sm text-white/75">
            {ui.requestNewLink}
          </div>

          <a
            href={withPortalBasePath("/forgot-password")}
            class="portal-submit inline-flex w-full items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em]"
          >
            {ui.requestNewLinkCta}
          </a>
        </div>
      )
    }
  </AuthShell>
</BaseLayout>
