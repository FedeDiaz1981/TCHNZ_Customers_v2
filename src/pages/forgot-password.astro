---
import AuthShell from "../components/portal/AuthShell.astro";
import TurnstileWidget from "../components/portal/TurnstileWidget.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { turnstileSiteKey } from "../lib/auth/public";
import { getCustomerLocale, getCustomerUi } from "../lib/i18n/customers";
import { withPortalBasePath } from "../lib/portal/base-path";

const error = Astro.url.searchParams.get("error");
const message = Astro.url.searchParams.get("message");
const locale = getCustomerLocale(Astro.url, Astro.cookies);
const ui = getCustomerUi(locale).forgotPassword;
---

<BaseLayout title={ui.title} description={ui.description} lang={locale}>
  <AuthShell
    eyebrow={ui.eyebrow}
    heading={ui.heading}
    copy={ui.copy}
    locale={locale}
    footerCopy={getCustomerUi(locale).authShell.footer}
  >
    <div class="mb-8">
      <p class="portal-eyebrow text-sm">{ui.overline}</p>
      <h2 class="mt-2 text-3xl font-semibold">{ui.cardHeading}</h2>
      <p class="portal-copy mt-2 text-sm">{ui.cardCopy}</p>
    </div>

    {error && (
      <div class="mb-6 rounded-2xl border border-red-400/25 bg-red-500/10 px-4 py-3 text-sm text-red-100">
        {error}
      </div>
    )}

    {message && (
      <div class="mb-6 rounded-2xl border border-emerald-400/25 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-50">
        {message}
      </div>
    )}

    <form action={withPortalBasePath("/api/auth/forgot-password")} method="POST" class="space-y-5">
      <label class="block">
        <span class="mb-2 block text-sm font-medium text-white/80">{ui.email}</span>
        <input
          type="email"
          name="email"
          autocomplete="email"
          required
          class="portal-input w-full rounded-2xl px-4 py-3"
          placeholder="cliente@empresa.com"
        />
      </label>

      <TurnstileWidget siteKey={turnstileSiteKey} action="forgot_password" locale={locale} />

      <button
        type="submit"
        class="portal-submit inline-flex w-full items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em]"
      >
        {ui.submit}
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-white/60">
      <a href={withPortalBasePath("/login")} class="text-white transition hover:text-white/80">{ui.backToLogin}</a>
    </p>
  </AuthShell>

  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
    async
    defer
  ></script>
</BaseLayout>
