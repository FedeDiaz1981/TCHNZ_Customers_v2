---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getAdminFlash } from "../../lib/portal/admin-flash";
import { getAdminClients } from "../../lib/portal/admin";
import { getPortalModuleConfig } from "../../lib/portal/modules";
import { withPortalBasePath } from "../../lib/portal/base-path";

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;
const moduleConfig = getPortalModuleConfig(portalModule);

if (!user || !supabase) {
  return Astro.redirect("/login");
}

const flash = getAdminFlash(Astro.url);
const clients = await getAdminClients(supabase, portalModule);

const dateFormatter = new Intl.DateTimeFormat("es-AR", {
  day: "2-digit",
  month: "short",
  year: "numeric"
});

function getInitials(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((chunk) => chunk[0]?.toUpperCase() ?? "")
    .join("");
}

function getDialogId(clientId: string) {
  return `client-dialog-${clientId}`;
}
---

<AdminLayout
  title={`${moduleConfig.entity.plural.es} | Administracion portal`}
  description={`Gestion de ${moduleConfig.entity.plural.es.toLowerCase()} del modulo`}
  userEmail={user.email ?? ""}
  activePath="/admin/clientes"
  portalModule={portalModule}
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    {flash && (
      <div
        class:list={[
          "mb-6 rounded-3xl border px-4 py-3.5 text-sm sm:px-5 sm:py-4",
          flash.tone === "error"
            ? "border-red-400/30 bg-red-500/10 text-red-50"
            : "border-emerald-400/30 bg-emerald-500/10 text-emerald-50"
        ]}
      >
        {flash.message}
      </div>
    )}

    <section class="space-y-6">
      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Base de {moduleConfig.entity.plural.es.toLowerCase()}</p>
            <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">Grilla operativa</h2>
            <p class="portal-copy mt-2 hidden text-sm leading-6 sm:block">
              Pensada para operar rapido: ves todo en una tabla clara y, al abrir un registro,
              el modal concentra el detalle sin desbordar la pantalla ni romper el look corporativo.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <span class="self-start rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70 sm:self-auto">
              {clients.length} {moduleConfig.entity.plural.es.toLowerCase()}
            </span>
            <button
              type="button"
              class="portal-action-link portal-action-link--solid w-full justify-center sm:w-auto"
              data-open-dialog="create-client-dialog"
            >
              Nueva {moduleConfig.entity.singular.es.toLowerCase()}
            </button>
          </div>
        </div>
      </div>

      <div class="portal-panel rounded-[30px] p-0">
        <div class="px-4 pt-4 sm:px-6 sm:pt-5">
          <div class="admin-grid-toolbar">
            <label class="admin-grid-search">
              <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              <input
                type="search"
                placeholder="Buscar cliente por nombre, slug o estado"
                data-client-search
              />
            </label>

            <p class="portal-copy hidden text-xs sm:block sm:text-sm">
              Click en una fila para abrir el detalle y editar sin salir de la grilla.
            </p>
          </div>
        </div>

        <div class="overflow-x-auto">
          <div class="px-4 pb-4 sm:px-6 sm:pb-5">
            <div class="admin-grid-head">
              <span>Cliente</span>
              <span>Estado</span>
              <span>Usuarios</span>
              <span>Managers</span>
              <span>Apps</span>
              <span>Alta</span>
              <span class="text-right">Accion</span>
            </div>

            <div class="mt-3 space-y-3" data-client-rows>
              {clients.map((client) => {
                const dialogId = getDialogId(client.id);
                const logoUrl = client.logoUrl?.trim() ?? "";
                const initials = getInitials(client.name);
                const searchIndex = `${client.name} ${client.slug} ${
                  client.isActive ? "activo" : "inactivo"
                }`.toLowerCase();

                return (
                  <>
                    <button
                      type="button"
                      class="admin-grid-row"
                      data-open-dialog={dialogId}
                      data-client-row
                      data-client-search-value={searchIndex}
                      aria-label={`Abrir detalle de ${client.name}`}
                    >
                      <span class="admin-grid-row__identity flex min-w-0 items-center gap-3 text-left">
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-white/10 bg-white/5">
                          {logoUrl ? (
                            <img
                              src={logoUrl}
                              alt={`Logo de ${client.name}`}
                              class="h-full w-full object-contain p-1"
                            />
                          ) : (
                            <span class="text-sm font-semibold tracking-[0.12em] text-white/75">
                              {initials}
                            </span>
                          )}
                        </span>

                        <span class="min-w-0">
                          <strong class="block truncate text-sm text-white">{client.name}</strong>
                          <span class="portal-copy block truncate text-[11px] uppercase tracking-[0.14em]">
                            {client.slug}
                          </span>
                        </span>
                      </span>

                      <span class="admin-grid-row__state">
                        <span
                          class:list={[
                            "inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em]",
                            client.isActive
                              ? "border border-emerald-400/20 bg-emerald-500/10 text-emerald-100"
                              : "border border-white/10 bg-white/5 text-white/55"
                          ]}
                        >
                          {client.isActive ? "Activo" : "Inactivo"}
                        </span>
                      </span>

                      <span class="admin-grid-row__metric admin-grid-row__metric--users">
                        <span class="admin-grid-row__metric-label">Usuarios</span>
                        <strong class="text-sm font-semibold text-white">{client.membershipsCount}</strong>
                      </span>
                      <span class="admin-grid-row__metric admin-grid-row__metric--managers">
                        <span class="admin-grid-row__metric-label">Managers</span>
                        <strong class="text-sm font-semibold text-white">{client.managersCount}</strong>
                      </span>
                      <span class="admin-grid-row__metric admin-grid-row__metric--apps">
                        <span class="admin-grid-row__metric-label">Apps</span>
                        <strong class="text-sm font-semibold text-white">{client.enabledApplicationsCount}</strong>
                      </span>
                      <span class="admin-grid-row__date text-sm text-white/80">
                        <span class="admin-grid-row__date-label">Alta</span>
                        {dateFormatter.format(new Date(client.createdAt))}
                      </span>
                      <span class="admin-grid-row__action text-right text-xs font-semibold uppercase tracking-[0.18em] text-[#ff8c1a]">
                        Abrir
                      </span>
                    </button>

                    <dialog id={dialogId} data-admin-dialog class="admin-dialog">
                      <div class="admin-dialog__panel portal-panel rounded-[32px] p-0">
                        <div class="admin-dialog__header flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4 sm:px-6">
                          <div>
                            <p class="portal-eyebrow text-[11px]">Detalle de cliente</p>
                            <h3 class="mt-2 text-xl font-semibold text-white sm:text-2xl">{client.name}</h3>
                            <p class="portal-copy mt-1 text-sm">
                              Consulta y edita identidad, estado y datos base del cliente.
                            </p>
                          </div>

                          <button
                            type="button"
                            class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
                            data-close-dialog
                          >
                            Cerrar
                          </button>
                        </div>

                        <form
                          action={withPortalBasePath("/api/admin/manage")}
                          method="POST"
                          enctype="multipart/form-data"
                          class="flex max-h-[82vh] flex-col"
                        >
                          <input type="hidden" name="action" value="update-client" />
                          <input type="hidden" name="redirect_to" value="/admin/clientes" />
                          <input type="hidden" name="client_id" value={client.id} />
                          <input type="hidden" name="current_logo_url" value={logoUrl} />

                          <div class="admin-dialog__body overflow-y-auto px-5 py-5 sm:px-6">
                            <div class="grid gap-5 xl:grid-cols-[250px_minmax(0,1fr)]">
                              <aside class="space-y-4">
                                <div class="rounded-[28px] border border-white/10 bg-black/20 p-4">
                                  <div class="flex items-start justify-between gap-3">
                                    <div>
                                      <p class="portal-copy text-xs uppercase tracking-[0.14em]">
                                        Identidad visual
                                      </p>
                                      <strong class="mt-2 block text-base text-white">
                                        {client.name}
                                      </strong>
                                    </div>
                                    <span
                                      class:list={[
                                        "inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em]",
                                        client.isActive
                                          ? "border border-emerald-400/20 bg-emerald-500/10 text-emerald-100"
                                          : "border border-white/10 bg-white/5 text-white/55"
                                      ]}
                                    >
                                      {client.isActive ? "Activo" : "Inactivo"}
                                    </span>
                                  </div>

                                  <div class="mt-4 flex h-32 items-center justify-center overflow-hidden rounded-[24px] border border-white/10 bg-white/5 p-3">
                                    <img
                                      src={logoUrl || "/customers/assets/brand/logo-technized-tr.png"}
                                      alt={`Preview logo ${client.name}`}
                                      class="h-full w-full object-contain"
                                      data-logo-preview
                                      data-current-src={logoUrl || "/customers/assets/brand/logo-technized-tr.png"}
                                      data-fallback-src="/customers/assets/brand/logo-technized-tr.png"
                                    />
                                  </div>

                                  <p class="portal-copy mt-3 text-xs leading-5">
                                    Este cliente agrupa usuarios y aplicaciones dentro del portal.
                                    Su logo institucional se actualiza solo subiendo una nueva imagen.
                                  </p>
                                </div>

                                <div class="grid grid-cols-3 gap-3 xl:grid-cols-1">
                                  <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4">
                                    <p class="portal-copy text-[11px] uppercase tracking-[0.14em]">Usuarios</p>
                                    <strong class="mt-2 block text-2xl text-white">
                                      {client.membershipsCount}
                                    </strong>
                                  </div>
                                  <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4">
                                    <p class="portal-copy text-[11px] uppercase tracking-[0.14em]">Managers</p>
                                    <strong class="mt-2 block text-2xl text-white">
                                      {client.managersCount}
                                    </strong>
                                  </div>
                                  <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4">
                                    <p class="portal-copy text-[11px] uppercase tracking-[0.14em]">Apps</p>
                                    <strong class="mt-2 block text-2xl text-white">
                                      {client.enabledApplicationsCount}
                                    </strong>
                                  </div>
                                </div>
                              </aside>

                              <div class="space-y-5">
                                <div class="rounded-[28px] border border-white/10 bg-black/20 p-4 sm:p-5">
                                  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                    <div>
                                      <p class="portal-copy text-xs uppercase tracking-[0.14em]">
                                        Datos principales
                                      </p>
                                      <p class="portal-copy mt-1 text-sm">
                                        Nombre visible, identificador interno y logo institucional del cliente.
                                      </p>
                                    </div>
                                    <span class="rounded-full border border-white/10 px-3 py-1 text-xs uppercase tracking-[0.14em] text-white/60">
                                      Alta {dateFormatter.format(new Date(client.createdAt))}
                                    </span>
                                  </div>

                                  <div class="mt-4 grid gap-4 lg:grid-cols-2">
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
                                      <input
                                        class="portal-input w-full rounded-2xl px-4 py-3"
                                        type="text"
                                        name="name"
                                        value={client.name}
                                        required
                                      />
                                    </label>

                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Slug</span>
                                      <input
                                        class="portal-input w-full rounded-2xl px-4 py-3"
                                        type="text"
                                        name="slug"
                                        value={client.slug}
                                        required
                                      />
                                    </label>
                                  </div>

                                  <label class="mt-4 block">
                                    <span class="mb-2 block text-sm font-medium text-white/80">
                                      Logo institucional
                                    </span>
                                    <span class="mt-2 block text-xs text-white/45">
                                      Si no subes una nueva imagen, se conserva el logo actual.
                                    </span>
                                  </label>

                                  <label class="mt-4 block">
                                    <span class="mb-2 block text-sm font-medium text-white/80">
                                      Subir archivo de logo
                                    </span>
                                    <input
                                      class="admin-file-input w-full rounded-2xl px-4 py-3"
                                      type="file"
                                      name="logo_file"
                                      accept="image/png,image/jpeg,image/webp"
                                      data-logo-file-input
                                    />
                                    <div class="mt-2 flex flex-wrap items-center justify-between gap-2">
                                      <span class="text-xs text-white/55" data-logo-file-name>
                                        Ningun archivo seleccionado.
                                      </span>
                                      <button
                                        type="button"
                                        class="admin-file-clear"
                                        data-clear-logo-file
                                      >
                                        Quitar archivo
                                      </button>
                                    </div>
                                    <p class="portal-copy mt-2 text-xs leading-5">
                                      Si subes una imagen, reemplaza el logo actual del cliente.
                                      Formatos permitidos: PNG, JPG o WEBP. Maximo 5 MB.
                                    </p>
                                  </label>
                                </div>

                                <div class="rounded-[28px] border border-white/10 bg-black/20 p-4 sm:p-5">
                                  <p class="portal-copy text-xs uppercase tracking-[0.14em]">
                                    Estado y operacion
                                  </p>
                                  <div class="mt-4 grid gap-4 lg:grid-cols-[1.25fr_0.75fr]">
                                    <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                                      <p class="text-sm leading-6 text-white/85">
                                        Si este cliente queda inactivo, deja de operar en el portal y
                                        no participa en accesos ni vistas operativas para usuarios.
                                      </p>
                                    </div>

                                    <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
                                      <input type="hidden" name="is_active" value="false" />
                                      <input
                                        type="checkbox"
                                        name="is_active"
                                        value="true"
                                        checked={client.isActive}
                                        class="h-4 w-4"
                                      />
                                      Cliente activo
                                    </label>
                                  </div>

                                  <div class="mt-4 rounded-2xl border border-red-400/20 bg-red-500/8 px-4 py-4">
                                    <p class="text-sm font-semibold text-red-100">
                                      Eliminar cliente
                                    </p>
                                    <p class="mt-2 text-sm leading-6 text-red-50/80">
                                      Esta accion quita el cliente de la lista operativa y desactiva
                                      tambien sus membresias y accesos asociados.
                                    </p>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div class="admin-dialog__footer flex flex-wrap items-center justify-between gap-3 border-t border-white/10 px-5 py-4 sm:px-6">
                            <button
                              type="submit"
                              name="intent"
                              value="delete-client"
                              class="inline-flex items-center justify-center rounded-full border border-red-400/25 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-100 transition hover:border-red-300/40 hover:bg-red-500/16"
                              data-confirm-submit="Vas a quitar este cliente de la lista y desactivar sus relaciones asociadas. Esta accion no se puede deshacer. żDeseas continuar?"
                            >
                              Eliminar cliente
                            </button>

                            <div class="flex flex-wrap items-center justify-end gap-3">
                            <button
                              type="button"
                              class="portal-action-link"
                              data-close-dialog
                            >
                              Cancelar
                            </button>
                            <button
                              type="submit"
                              class="portal-action-link portal-action-link--solid"
                            >
                              Guardar
                            </button>
                            </div>
                          </div>
                        </form>
                      </div>
                    </dialog>
                  </>
                );
              })}
            </div>

            <div
              class="portal-empty-state mt-4 hidden rounded-[24px] px-4 py-5 text-sm"
              data-client-empty
            >
              No encontramos clientes con ese criterio. Proba con otro nombre o slug.
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <dialog id="create-client-dialog" data-admin-dialog class="admin-dialog admin-dialog--compact">
    <div class="admin-dialog__panel portal-panel rounded-[32px] p-0">
      <div class="admin-dialog__header flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4 sm:px-6">
        <div>
          <p class="portal-eyebrow text-[11px]">Alta de cliente</p>
          <h3 class="mt-2 text-2xl font-semibold text-white">Nuevo cliente</h3>
          <p class="portal-copy mt-1 text-sm">
            Crea el encabezado institucional y deja listo su logo para el portal.
          </p>
        </div>

        <button
          type="button"
          class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
          data-close-dialog
        >
          Cerrar
        </button>
      </div>

      <form
        action={withPortalBasePath("/api/admin/manage")}
        method="POST"
        enctype="multipart/form-data"
        class="flex max-h-[82vh] flex-col"
      >
        <input type="hidden" name="action" value="create-client" />
        <input type="hidden" name="redirect_to" value="/admin/clientes" />

        <div class="admin-dialog__body overflow-y-auto px-5 py-5 sm:px-6">
          <div class="grid gap-5 xl:grid-cols-[220px_minmax(0,1fr)]">
            <div class="rounded-[28px] border border-white/10 bg-black/20 p-4">
              <p class="portal-copy text-xs uppercase tracking-[0.14em]">Vista previa</p>
              <div class="mt-4 flex h-32 items-center justify-center overflow-hidden rounded-[24px] border border-white/10 bg-white/5 p-3">
                <img
                  src="/customers/assets/brand/logo-technized-tr.png"
                  alt="Preview nuevo cliente"
                  class="h-full w-full object-contain"
                  data-logo-preview
                  data-current-src="/customers/assets/brand/logo-technized-tr.png"
                  data-fallback-src="/customers/assets/brand/logo-technized-tr.png"
                />
              </div>
              <p class="portal-copy mt-3 text-xs leading-5">
                Crea el cliente como cabecera institucional y carga su logo desde tu equipo.
              </p>
            </div>

            <div class="space-y-4 rounded-[28px] border border-white/10 bg-black/20 p-4 sm:p-5">
              <div>
                <p class="portal-copy text-xs uppercase tracking-[0.14em]">Datos iniciales</p>
                <p class="portal-copy mt-1 text-sm">
                  Crea el cliente como agrupador de usuarios, accesos y aplicaciones del portal.
                </p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <label class="block">
                  <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
                  <input
                    class="portal-input w-full rounded-2xl px-4 py-3"
                    type="text"
                    name="name"
                    placeholder="Cliente Demo Technized"
                    required
                  />
                </label>

                <label class="block">
                  <span class="mb-2 block text-sm font-medium text-white/80">Slug</span>
                  <input
                    class="portal-input w-full rounded-2xl px-4 py-3"
                    type="text"
                    name="slug"
                    placeholder="cliente-demo-technized"
                    required
                  />
                </label>
              </div>

              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Logo institucional</span>
                <span class="mt-2 block text-xs text-white/45">
                  El logo se define solo desde un archivo de imagen.
                </span>
              </label>

              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">
                  Subir archivo de logo
                </span>
                <input
                  class="admin-file-input w-full rounded-2xl px-4 py-3"
                  type="file"
                  name="logo_file"
                  accept="image/png,image/jpeg,image/webp"
                  data-logo-file-input
                />
                <div class="mt-2 flex flex-wrap items-center justify-between gap-2">
                  <span class="text-xs text-white/55" data-logo-file-name>
                    Ningun archivo seleccionado.
                  </span>
                  <button
                    type="button"
                    class="admin-file-clear"
                    data-clear-logo-file
                  >
                    Quitar archivo
                  </button>
                </div>
                <p class="portal-copy mt-2 text-xs leading-5">
                  Si eliges un archivo, ese logo se guardara en el portal y se usara para el cliente.
                  Formatos permitidos: PNG, JPG o WEBP. Maximo 5 MB.
                </p>
              </label>

              <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
                <input type="hidden" name="is_active" value="false" />
                <input type="checkbox" name="is_active" value="true" checked class="h-4 w-4" />
                Cliente activo desde el alta
              </label>
            </div>
          </div>
        </div>

        <div class="admin-dialog__footer flex flex-wrap items-center justify-end gap-3 border-t border-white/10 px-5 py-4 sm:px-6">
          <button type="button" class="portal-action-link" data-close-dialog>
            Cancelar
          </button>
          <button
            type="submit"
            class="portal-action-link portal-action-link--solid"
          >
            Guardar
          </button>
        </div>
      </form>
    </div>
  </dialog>
</AdminLayout>

<style>
  .admin-grid-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .admin-grid-search {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: min(100%, 420px);
    padding: 0.9rem 1rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .admin-grid-search i {
    color: rgba(255, 255, 255, 0.5);
  }

  .admin-grid-search input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font: inherit;
  }

