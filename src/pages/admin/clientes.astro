<script>
  function updateDialogLogoPreview(dialog) {
    if (!(dialog instanceof HTMLElement)) return;

    const preview = dialog.querySelector("[data-logo-preview]");
    if (!(preview instanceof HTMLImageElement)) return;

    const fileInput = dialog.querySelector("[data-logo-file-input]");
    const fileName = dialog.querySelector("[data-logo-file-name]");
    const currentSrc = preview.dataset.currentSrc || "";
    const fallback = preview.dataset.fallbackSrc || "";
    const previousObjectUrl = preview.dataset.objectUrl;
    const selectedFile =
      fileInput instanceof HTMLInputElement ? fileInput.files?.[0] ?? null : null;

    if (previousObjectUrl) {
      URL.revokeObjectURL(previousObjectUrl);
      delete preview.dataset.objectUrl;
    }

    if (fileName instanceof HTMLElement) {
      fileName.textContent = selectedFile ? selectedFile.name : "Ningun archivo seleccionado.";
    }

    if (selectedFile) {
      const objectUrl = URL.createObjectURL(selectedFile);
      preview.src = objectUrl;
      preview.dataset.objectUrl = objectUrl;
      return;
    }

    preview.src = currentSrc || fallback;
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const confirmSubmitTrigger = target.closest("[data-confirm-submit]");
    if (confirmSubmitTrigger instanceof HTMLButtonElement) {
      const message =
        confirmSubmitTrigger.dataset.confirmSubmit ||
        "Esta accion no se puede deshacer. żDeseas continuar?";

      if (!window.confirm(message)) {
        event.preventDefault();
        return;
      }
    }

    const openTrigger = target.closest("[data-open-dialog]");
    if (openTrigger instanceof HTMLElement) {
      const dialogId = openTrigger.dataset.openDialog;
      const dialog = dialogId ? document.getElementById(dialogId) : null;
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
        updateDialogLogoPreview(dialog);
      }
      return;
    }

    const clearFileTrigger = target.closest("[data-clear-logo-file]");
    if (clearFileTrigger instanceof HTMLElement) {
      const dialog = clearFileTrigger.closest("[data-admin-dialog]");
      const fileInput = dialog?.querySelector("[data-logo-file-input]");

      if (fileInput instanceof HTMLInputElement) {
        fileInput.value = "";
        updateDialogLogoPreview(dialog);
      }

      return;
    }

    const closeTrigger = target.closest("[data-close-dialog]");
    if (closeTrigger instanceof HTMLElement) {
      const dialog = closeTrigger.closest("dialog");
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
    }
  });

  document.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;

    if (target.matches("[data-client-search]")) {
      const query = target.value.trim().toLowerCase();
      const rows = document.querySelectorAll("[data-client-row]");
      let visibleCount = 0;

      rows.forEach((row) => {
        if (!(row instanceof HTMLElement)) return;
        const value = row.dataset.clientSearchValue || "";
        const match = !query || value.includes(query);
        row.style.display = match ? "" : "none";
        if (match) visibleCount += 1;
      });

      const emptyState = document.querySelector("[data-client-empty]");
      if (emptyState instanceof HTMLElement) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    }
  });

  document.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;

    if (target.matches("[data-logo-file-input]")) {
      updateDialogLogoPreview(target.closest("[data-admin-dialog]"));
    }
  });

  document.querySelectorAll("dialog[data-admin-dialog]").forEach((dialogNode) => {
    if (!(dialogNode instanceof HTMLDialogElement)) return;

    dialogNode.addEventListener("cancel", () => {
      dialogNode.close();
    });

    dialogNode.addEventListener("click", (event) => {
      const target = event.target;
      if (target === dialogNode) {
        dialogNode.close();
      }
    });

    updateDialogLogoPreview(dialogNode);
  });
</script>
