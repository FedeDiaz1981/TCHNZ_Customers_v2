    }

    .admin-blog-row__date,
    .admin-blog-row__tags,
    .admin-blog-row__featured,
    .admin-blog-pill {
      min-width: 0;
      padding: 0.7rem 0.75rem;
      border-radius: 0.95rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
    }

