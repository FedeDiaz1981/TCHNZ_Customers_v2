</style>

<script>
  function resetDialogForm(dialog) {
    if (!(dialog instanceof HTMLDialogElement) || dialog.dataset.resetOnOpen !== "true") {
      return;
    }

    const form = dialog.querySelector("form");
    if (form instanceof HTMLFormElement) {
      form.reset();
    }

    dialog.querySelectorAll("[data-password-input]").forEach((field) => {
      if (field instanceof HTMLInputElement) {
        field.type = "password";
      }
    });

    dialog.querySelectorAll("[data-password-toggle]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.setAttribute("aria-pressed", "false");
      button.setAttribute("aria-label", "Mostrar contrasena");

      const icon = button.querySelector("i");
      if (icon instanceof HTMLElement) {
        icon.classList.add("fa-eye");
        icon.classList.remove("fa-eye-slash");
      }
    });
  }

  function syncAdminMembershipState(scope) {
    if (!(scope instanceof HTMLElement)) return;

    const adminCheckbox = scope.querySelector("[data-admin-checkbox]");
    const membershipPanel = scope.querySelector("[data-membership-panel]");

    if (!(adminCheckbox instanceof HTMLInputElement) || !(membershipPanel instanceof HTMLElement)) {
      return;
    }

    membershipPanel.classList.remove("hidden");

    membershipPanel
      .querySelectorAll("input, select, textarea")
      .forEach((field) => {
        if (
          !(
            field instanceof HTMLInputElement ||
            field instanceof HTMLSelectElement ||
            field instanceof HTMLTextAreaElement
          )
        ) {
          return;
        }

        field.disabled = false;
      });
  }

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const confirmSubmitTrigger = target.closest("[data-confirm-submit]");
    if (confirmSubmitTrigger instanceof HTMLButtonElement) {
      const message =
        confirmSubmitTrigger.dataset.confirmSubmit ||
        "Esta accion no se puede deshacer. ¿Deseas continuar?";

      if (!window.confirm(message)) {
        event.preventDefault();
        return;
      }
    }

    const openTrigger = target.closest("[data-open-dialog]");
    if (openTrigger instanceof HTMLElement) {
      const dialogId = openTrigger.dataset.openDialog;
      const dialog = dialogId ? document.getElementById(dialogId) : null;
      if (dialog instanceof HTMLDialogElement) {
        resetDialogForm(dialog);
        dialog.showModal();
        syncAdminMembershipState(dialog);
      }
      return;
    }

    const closeTrigger = target.closest("[data-close-dialog]");
    if (closeTrigger instanceof HTMLElement) {
      const dialog = closeTrigger.closest("dialog");
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
      return;
    }

    const passwordToggle = target.closest("[data-password-toggle]");
    if (passwordToggle instanceof HTMLButtonElement) {
      const field = passwordToggle.closest(".admin-password-field");
      const input = field?.querySelector("[data-password-input]");
      const icon = passwordToggle.querySelector("i");

      if (input instanceof HTMLInputElement) {
        const nextType = input.type === "password" ? "text" : "password";
        const isVisible = nextType === "text";
        input.type = nextType;
        passwordToggle.setAttribute("aria-pressed", String(isVisible));
        passwordToggle.setAttribute(
          "aria-label",
          isVisible ? "Ocultar contrasena" : "Mostrar contrasena"
        );

        if (icon instanceof HTMLElement) {
          icon.classList.toggle("fa-eye", !isVisible);
          icon.classList.toggle("fa-eye-slash", isVisible);
        }
      }
    }
  });

  document.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;

    if (target.matches("[data-admin-checkbox]")) {
      syncAdminMembershipState(target.closest("dialog"));
      return;
    }

    if (!target.matches("[data-user-search]")) return;

    const query = target.value.trim().toLowerCase();
    const rows = document.querySelectorAll("[data-user-row]");
    let visibleCount = 0;

    rows.forEach((row) => {
      if (!(row instanceof HTMLElement)) return;
      const value = row.dataset.userSearchValue || "";
      const match = !query || value.includes(query);
      row.style.display = match ? "" : "none";
      if (match) visibleCount += 1;
    });

    const emptyState = document.querySelector("[data-user-empty]");
    if (emptyState instanceof HTMLElement) {
      emptyState.classList.toggle("hidden", visibleCount > 0);
    }
  });

  document.querySelectorAll("dialog[data-admin-dialog]").forEach((dialogNode) => {
    if (!(dialogNode instanceof HTMLDialogElement)) return;

    dialogNode.addEventListener("cancel", () => {
      dialogNode.close();
    });

    dialogNode.addEventListener("click", (event) => {
      if (event.target === dialogNode) {
        dialogNode.close();
      }
    });

    syncAdminMembershipState(dialogNode);
  });
</script>
