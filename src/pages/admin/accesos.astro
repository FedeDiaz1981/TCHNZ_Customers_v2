---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getAdminAccessMatrix, hasAccessPair } from "../../lib/portal/admin";
import { getAdminFlash } from "../../lib/portal/admin-flash";
import { getPortalModuleConfig } from "../../lib/portal/modules";
import { withPortalBasePath } from "../../lib/portal/base-path";

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;
const moduleConfig = getPortalModuleConfig(portalModule);

if (!user || !supabase) {
  return Astro.redirect("/login");
}

const flash = getAdminFlash(Astro.url);
const matrix = await getAdminAccessMatrix(supabase, portalModule);
const manageAccessHref = withPortalBasePath("/api/admin/manage");

const applicationCategories = Array.from(new Set(matrix.applications.map((application) => application.category))).sort();

function getEnabledCount(clientId: string) {
  return matrix.applications.reduce((count, application) => {
    return count + (hasAccessPair(matrix, clientId, application.id) ? 1 : 0);
  }, 0);
}

const clientCards = matrix.clients.map((client) => {
  const enabledCount = getEnabledCount(client.id);
  const searchValue = `${client.name} ${client.slug} ${client.isActive ? "activo" : "inactivo"} ${enabledCount}`.toLowerCase();

  return {
    ...client,
    enabledCount,
    searchValue
  };
});

const accessData = {
  clients: clientCards,
  applications: matrix.applications.map((application) => ({
    ...application,
    searchValue: `${application.name} ${application.slug} ${application.category} ${application.availabilityStatus}`.toLowerCase()
  })),
  categories: applicationCategories,
  enabledPairs: Array.from(matrix.enabledPairs),
  manageAccessHref
};

const accessDataJson = JSON.stringify(accessData).replace(/</g, "\\u003c");
---

<AdminLayout
  title={`Accesos ${moduleConfig.name.es} | Administracion portal`}
  description={`Gestion de accesos por cliente y aplicacion de ${moduleConfig.name.es}`}
  userEmail={user.email ?? ""}
  activePath="/admin/accesos"
  portalModule={portalModule}
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    {flash && (
      <div
        class:list={[
          "mb-6 rounded-3xl border px-4 py-3.5 text-sm sm:px-5 sm:py-4",
          flash.tone === "error"
            ? "border-red-400/30 bg-red-500/10 text-red-50"
            : "border-emerald-400/30 bg-emerald-500/10 text-emerald-50"
        ]}
      >
        {flash.message}
      </div>
    )}

    <section class="space-y-6">
      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Control de permisos</p>
            <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">
              Clientes y accesos por panel
            </h2>
            <p class="portal-copy mt-2 hidden text-sm leading-6 sm:block">
              Selecciona un cliente para abrir un panel dedicado con buscador, filtros y una lista
              de aplicaciones editable. El flujo queda mucho mas simple cuando el catalogo crece.
            </p>
          </div>

          <div class="flex flex-wrap gap-3 text-sm">
            <span class="rounded-full bg-emerald-500/15 px-3 py-2 text-emerald-100">
              {matrix.clients.length} clientes
            </span>
            <span class="rounded-full bg-white/10 px-3 py-2 text-white/70">
              {matrix.applications.length} aplicaciones
            </span>
          </div>
        </div>
      </div>

      <section class="portal-panel rounded-[30px] p-0">
        <div class="px-4 pt-4 sm:px-6 sm:pt-5">
          <div class="admin-access-toolbar">
            <label class="admin-access-search">
              <i class="fa-solid fa-building" aria-hidden="true"></i>
              <input
                type="search"
                placeholder="Buscar cliente"
                data-access-client-search
              />
            </label>

            <div class="admin-access-toolbar__copy">
              <p class="text-sm font-medium text-white/90">
                Abre un cliente y gestiona sus aplicaciones en un modal con scroll y filtros.
              </p>
              <p class="portal-copy mt-1 text-xs">
                La matriz completa ya no es necesaria para el trabajo diario.
              </p>
            </div>
          </div>
        </div>

        <div class="px-4 pb-4 pt-4 sm:px-6 sm:pb-6">
          <div class="admin-access-table-wrap">
            <table class="admin-access-clients-table" data-access-client-list>
              <thead>
                <tr>
                  <th>Cliente</th>
                  <th>Estado</th>
                  <th>Accesos</th>
                  <th>Accion</th>
                </tr>
              </thead>
              <tbody>
                {clientCards.map((client) => (
                  <tr
                    data-access-client-card
                    data-client-id={client.id}
                    data-access-client-search-value={client.searchValue}
                  >
                    <td>
                      <div class="min-w-0">
                        <p class="truncate text-base font-semibold text-white">{client.name}</p>
                        <p class="portal-copy mt-1 truncate text-sm">/{client.slug}</p>
                      </div>
                    </td>
                    <td>
                      <span
                        class:list={[
                          "inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em]",
                          client.isActive
                            ? "bg-emerald-500/15 text-emerald-100"
                            : "bg-white/10 text-white/60"
                        ]}
                      >
                        {client.isActive ? "Activo" : "Pausado"}
                      </span>
                    </td>
                    <td>
                      <div class="admin-access-table-metrics">
                        <div class="admin-access-table-metric">
                          <span>Habilitadas</span>
                          <strong data-access-client-enabled-count>{client.enabledCount}</strong>
                        </div>
                        <div class="admin-access-table-metric">
                          <span>Total</span>
                          <strong>{matrix.applications.length}</strong>
                        </div>
                      </div>
                    </td>
                    <td>
                      <button
                        type="button"
                        class="portal-action-link portal-action-link--solid w-full justify-center"
                        data-open-access-dialog
                        data-client-id={client.id}
                      >
                        Gestionar accesos
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="portal-empty-state mt-4 hidden rounded-[24px] px-4 py-5 text-sm" data-access-client-empty>
            No encontramos clientes para ese criterio de busqueda.
          </div>
        </div>
      </section>
    </section>
  </div>

  <dialog class="admin-access-dialog" data-access-dialog>
    <div class="admin-access-dialog__panel portal-panel rounded-[32px] p-0">
      <div class="admin-access-dialog__header border-b border-white/10 px-5 py-4 sm:px-6">
        <div class="min-w-0">
          <p class="portal-eyebrow text-[11px]">Gestor de accesos</p>
          <h3 class="mt-2 text-2xl font-semibold text-white" data-access-dialog-client-name>
            Cliente
          </h3>
          <p class="portal-copy mt-1 text-sm" data-access-dialog-client-slug></p>
        </div>

        <button
          type="button"
          class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
          data-close-access-dialog
        >
          Cerrar
        </button>
      </div>

      <div class="admin-access-dialog__body px-5 py-5 sm:px-6">
        <div class="admin-access-dialog__summary">
          <div class="admin-access-dialog__summary-card">
            <span>Habilitadas</span>
            <strong data-access-dialog-enabled-count>0</strong>
          </div>
          <div class="admin-access-dialog__summary-card">
            <span>Total aplicaciones</span>
            <strong data-access-dialog-total-count>0</strong>
          </div>
          <div class="admin-access-dialog__summary-card">
            <span>Cliente</span>
            <strong data-access-dialog-client-status>Activo</strong>
          </div>
        </div>

        <div class="admin-access-dialog__toolbar">
          <label class="admin-access-search admin-access-search--compact">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <input
              type="search"
              placeholder="Buscar aplicacion"
              data-access-dialog-search
            />
          </label>

          <div class="admin-access-dialog__filters" data-access-dialog-filters>
            <button type="button" class="admin-access-chip is-active" data-access-category-filter="all">
              Todas
            </button>
            {applicationCategories.map((category) => (
              <button type="button" class="admin-access-chip" data-access-category-filter={category}>
                {category}
              </button>
            ))}
          </div>
        </div>

        <div class="mt-5">
          <div class="admin-access-dialog__apps" data-access-dialog-list></div>

          <div class="portal-empty-state hidden rounded-[24px] px-4 py-5 text-sm" data-access-dialog-empty>
            No encontramos aplicaciones para ese filtro.
          </div>
        </div>
      </div>
    </div>
  </dialog>

  <script type="application/json" id="admin-access-data" set:html={accessDataJson}></script>

  <script is:inline>
    (() => {
      const dataNode = document.getElementById("admin-access-data");
      const clientSearchInput = document.querySelector("[data-access-client-search]");
      const clientCards = Array.from(document.querySelectorAll("[data-access-client-card]"));
      const clientEmpty = document.querySelector("[data-access-client-empty]");
      const dialog = document.querySelector("[data-access-dialog]");
      const dialogClientName = document.querySelector("[data-access-dialog-client-name]");
      const dialogClientSlug = document.querySelector("[data-access-dialog-client-slug]");
      const dialogEnabledCount = document.querySelector("[data-access-dialog-enabled-count]");
      const dialogTotalCount = document.querySelector("[data-access-dialog-total-count]");
      const dialogClientStatus = document.querySelector("[data-access-dialog-client-status]");
      const dialogSearchInput = document.querySelector("[data-access-dialog-search]");
      const dialogFilters = document.querySelector("[data-access-dialog-filters]");
      const dialogList = document.querySelector("[data-access-dialog-list]");
      const dialogEmpty = document.querySelector("[data-access-dialog-empty]");
      const openButtons = Array.from(document.querySelectorAll("[data-open-access-dialog]"));
      const closeButtons = Array.from(document.querySelectorAll("[data-close-access-dialog]"));

      if (
        !(dataNode instanceof HTMLScriptElement) ||
        !(clientSearchInput instanceof HTMLInputElement) ||
        !(dialog instanceof HTMLDialogElement) ||
        !(dialogClientName instanceof HTMLElement) ||
        !(dialogClientSlug instanceof HTMLElement) ||
        !(dialogEnabledCount instanceof HTMLElement) ||
        !(dialogTotalCount instanceof HTMLElement) ||
        !(dialogClientStatus instanceof HTMLElement) ||
        !(dialogSearchInput instanceof HTMLInputElement) ||
        !(dialogFilters instanceof HTMLElement) ||
        !(dialogList instanceof HTMLElement) ||
        !(dialogEmpty instanceof HTMLElement)
      ) {
        return;
      }

      const data = JSON.parse(dataNode.textContent || "{}");
      const enabledPairs = new Set(Array.isArray(data.enabledPairs) ? data.enabledPairs : []);
      const clients = Array.isArray(data.clients) ? data.clients : [];
      const applications = Array.isArray(data.applications) ? data.applications : [];
      const manageAccessHref = typeof data.manageAccessHref === "string" ? data.manageAccessHref : "/api/admin/manage";

      const state = {
        clientId: null,
        query: "",
        category: "all"
      };

      function getEnabledKey(clientId, applicationId) {
        return `${clientId}::${applicationId}`;
      }

      function getClient(clientId) {
        return clients.find((client) => client.id === clientId) ?? null;
      }

      function syncClientRow(client) {
        const row = document.querySelector(`[data-access-client-card][data-client-id="${client.id}"]`);
        if (!(row instanceof HTMLElement)) return;

        const enabledCountNode = row.querySelector("[data-access-client-enabled-count]");
        if (enabledCountNode instanceof HTMLElement) {
          enabledCountNode.textContent = String(client.enabledCount);
        }

        row.dataset.accessClientSearchValue = `${client.name} ${client.slug} ${client.isActive ? "activo" : "inactivo"} ${client.enabledCount}`.toLowerCase();
      }

      function applyClientFilters() {
        const query = clientSearchInput.value.trim().toLowerCase();
        let visible = 0;

        clientCards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;

          const value = card.dataset.accessClientSearchValue || "";
          const match = !query || value.includes(query);
          card.style.display = match ? "" : "none";
          if (match) visible += 1;
        });

        if (clientEmpty instanceof HTMLElement) {
          clientEmpty.classList.toggle("hidden", visible > 0);
        }
      }

      function createAppCard(clientId, application) {
        const enabled = enabledPairs.has(getEnabledKey(clientId, application.id));
        const card = document.createElement("article");
        card.className = `admin-access-app-card ${enabled ? "is-enabled" : "is-disabled"}`;
        card.dataset.category = application.category;
        card.dataset.search = application.searchValue;

        const top = document.createElement("div");
        top.className = "admin-access-app-card__top";

        const copy = document.createElement("div");
        copy.className = "min-w-0";

        const name = document.createElement("p");
        name.className = "text-base font-semibold text-white";
        name.textContent = application.name;

        const meta = document.createElement("p");
        meta.className = "portal-copy mt-1 text-xs";
        meta.textContent = `${application.category} · ${application.availabilityStatus}`;

        copy.append(name, meta);

        const badge = document.createElement("span");
        badge.className = `admin-access-app-card__badge ${enabled ? "is-on" : "is-off"}`;
        badge.textContent = enabled ? "Habilitada" : "Bloqueada";

        top.append(copy, badge);

        const body = document.createElement("p");
        body.className = "admin-access-app-card__description portal-copy text-sm leading-6";
        body.textContent = application.description || "Sin descripción";

        const footer = document.createElement("div");
        footer.className = "admin-access-app-card__footer";

        const availability = document.createElement("div");
        availability.className = "admin-access-app-card__availability";
        const availabilityLabel = document.createElement("strong");
        availabilityLabel.textContent = application.availabilityStatus;
        const availabilityCopy = document.createElement("span");
        availabilityCopy.textContent = enabled ? "Click para quitar acceso" : "Click para dar acceso";
        availability.append(availabilityLabel, availabilityCopy);

        const form = document.createElement("form");
        form.action = manageAccessHref;
        form.method = "POST";
        form.className = "w-full";
        form.dataset.accessToggleForm = "true";

        const actionInput = document.createElement("input");
        actionInput.type = "hidden";
        actionInput.name = "action";
        actionInput.value = "upsert-access";

        const redirect = document.createElement("input");
        redirect.type = "hidden";
        redirect.name = "redirect_to";
        redirect.value = "/admin/accesos";

        const clientInput = document.createElement("input");
        clientInput.type = "hidden";
        clientInput.name = "client_id";
        clientInput.value = clientId;

        const applicationInput = document.createElement("input");
        applicationInput.type = "hidden";
        applicationInput.name = "application_id";
        applicationInput.value = application.id;

        const enabledInput = document.createElement("input");
        enabledInput.type = "hidden";
        enabledInput.name = "is_enabled";
        enabledInput.value = enabled ? "false" : "true";

        const button = document.createElement("button");
        button.type = "submit";
        button.className = `admin-access-toggle ${enabled ? "admin-access-toggle--on" : "admin-access-toggle--off"}`;
        button.setAttribute("aria-label", `${enabled ? "Quitar" : "Dar"} acceso a ${application.name}`);

        const buttonTop = document.createElement("span");
        buttonTop.className = "admin-access-toggle__top";

        const buttonLabel = document.createElement("span");
        buttonLabel.className = "font-semibold";
        buttonLabel.textContent = enabled ? "On" : "Off";

        const buttonSwitch = document.createElement("span");
        buttonSwitch.className = `admin-access-toggle__switch ${enabled ? "is-on" : "is-off"}`;
        buttonSwitch.setAttribute("aria-hidden", "true");

        const buttonKnob = document.createElement("span");
        buttonKnob.className = "admin-access-toggle__knob";

        buttonSwitch.append(buttonKnob);
        buttonTop.append(buttonLabel, buttonSwitch);

        const buttonCopy = document.createElement("span");
        buttonCopy.className = "mt-2 block text-xs leading-5";
        buttonCopy.textContent = enabled ? "Click para pausar" : "Click para habilitar";

        button.append(buttonTop, buttonCopy);
        form.append(actionInput, redirect, clientInput, applicationInput, enabledInput, button);

        footer.append(availability, form);
        card.append(top, body, footer);

        return card;
      }

      function renderApplications() {
        if (!state.clientId) return;

        const client = getClient(state.clientId);
        if (!client) return;

        const filteredApplications = applications.filter((application) => {
          const matchesCategory = state.category === "all" || application.category === state.category;
          const matchesQuery = !state.query || application.searchValue.includes(state.query);
          return matchesCategory && matchesQuery;
        });

        dialogList.replaceChildren();

        filteredApplications.forEach((application) => {
          dialogList.append(createAppCard(state.clientId, application));
        });

        dialogEmpty.classList.toggle("hidden", filteredApplications.length > 0);
        dialogEnabledCount.textContent = String(client.enabledCount);
        dialogTotalCount.textContent = String(applications.length);
        dialogClientName.textContent = client.name;
        dialogClientSlug.textContent = `/${client.slug}`;
        dialogClientStatus.textContent = client.isActive ? "Activo" : "Pausado";
      }

      function setActiveCategory(category) {
        state.category = category;
        dialogFilters.querySelectorAll("[data-access-category-filter]").forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.classList.toggle("is-active", button.dataset.accessCategoryFilter === category);
        });
        renderApplications();
      }

      function openClient(clientId) {
        const client = getClient(clientId);
        if (!client || !(dialog instanceof HTMLDialogElement)) return;

        state.clientId = clientId;
        state.query = "";
        state.category = "all";
        dialogSearchInput.value = "";
        setActiveCategory("all");
        dialog.showModal();
        renderApplications();
        dialogSearchInput.focus();
      }

      function closeDialog() {
        if (dialog.open) {
          dialog.close();
        }
      }

      clientSearchInput.addEventListener("input", applyClientFilters);

      openButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener("click", () => {
          const clientId = button.dataset.clientId;
          if (clientId) openClient(clientId);
        });
      });

      closeButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener("click", closeDialog);
      });

      dialogSearchInput.addEventListener("input", () => {
        state.query = dialogSearchInput.value.trim().toLowerCase();
        renderApplications();
      });

      dialogFilters.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;

        const category = target.dataset.accessCategoryFilter;
        if (!category) return;

        setActiveCategory(category);
      });

      dialogList.addEventListener("submit", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLFormElement) || !target.matches("[data-access-toggle-form]")) return;

        event.preventDefault();

        const submitButton = target.querySelector("button[type='submit']");
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
        }

        try {
          const formData = new FormData(target);
          const clientId = String(formData.get("client_id") ?? "");
          const applicationId = String(formData.get("application_id") ?? "");
          const nextEnabled = String(formData.get("is_enabled") ?? "false") === "true";

          const formAction = target.getAttribute("action") ?? target.action;
          const response = await fetch(formAction, {
            method: "POST",
            body: formData,
            credentials: "same-origin"
          });

          if (!response.ok) {
            throw new Error("No pudimos actualizar el acceso.");
          }

          const key = getEnabledKey(clientId, applicationId);
          if (nextEnabled) {
            enabledPairs.add(key);
          } else {
            enabledPairs.delete(key);
          }

          const client = getClient(clientId);
          if (client) {
            client.enabledCount = applications.reduce((count, item) => {
              return count + (enabledPairs.has(getEnabledKey(client.id, item.id)) ? 1 : 0);
            }, 0);
            syncClientRow(client);
          }

          renderApplications();
        } catch (error) {
          console.error(error);
          window.alert("No pudimos actualizar el acceso. Intenta de nuevo.");
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
          }
        }
      });

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });

      dialog.addEventListener("close", () => {
        state.clientId = null;
        state.query = "";
        state.category = "all";
        dialogList.replaceChildren();
        dialogSearchInput.value = "";
        setActiveCategory("all");
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && dialog.open) {
          closeDialog();
        }
      });

      applyClientFilters();
    })();
  </script>

  <style>
    .admin-access-toolbar {
      display: grid;
      gap: 1rem;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      align-items: center;
    }

    .admin-access-toolbar__copy {
      display: grid;
      gap: 0.15rem;
      align-self: stretch;
      padding: 0.95rem 1rem;
      border-radius: 1.1rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
    }

    .admin-access-search {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.95rem 1rem;
      border-radius: 1.1rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.04);
    }

    .admin-access-search--compact {
      width: 100%;
      padding: 0.9rem 1rem;
    }

    .admin-access-search i {
      color: rgba(255, 255, 255, 0.5);
    }

    .admin-access-search input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font: inherit;
    }

    .admin-access-search input::placeholder {
      color: rgba(255, 255, 255, 0.42);
    }

    .admin-access-table-wrap {
      overflow-x: auto;
      border-radius: 1.45rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.02);
    }

    .admin-access-clients-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 920px;
    }

    .admin-access-clients-table thead th {
      padding: 1rem 1rem 0.9rem;
      text-align: left;
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.52);
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .admin-access-clients-table tbody td {
      padding: 1rem;
      vertical-align: middle;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .admin-access-clients-table tbody tr {
      background: rgba(255, 255, 255, 0.01);
      transition: background-color 0.18s ease;
    }

    .admin-access-clients-table tbody tr:hover {
      background: rgba(255, 255, 255, 0.03);
    }

    .admin-access-table-metrics {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .admin-access-table-metric {
      display: grid;
      gap: 0.3rem;
      min-width: 100px;
      padding: 0.7rem 0.8rem;
      border-radius: 1rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
    }

    .admin-access-table-metric span {
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.5);
    }

    .admin-access-table-metric strong {
      font-size: 1.15rem;
      line-height: 1;
      color: #fff;
    }

    .admin-access-dialog {
