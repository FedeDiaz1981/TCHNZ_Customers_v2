<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const confirmSubmitTrigger = target.closest("[data-confirm-submit]");
    if (confirmSubmitTrigger instanceof HTMLButtonElement) {
      const message = confirmSubmitTrigger.dataset.confirmSubmit;
      if (message && !window.confirm(message)) {
        event.preventDefault();
      }
      return;
    }

    const openTrigger = target.closest("[data-open-dialog]");
    if (openTrigger instanceof HTMLElement) {
      const dialogId = openTrigger.dataset.openDialog;
      const dialog = dialogId ? document.getElementById(dialogId) : null;
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
      return;
    }

    const closeTrigger = target.closest("[data-close-dialog]");
    if (closeTrigger instanceof HTMLElement) {
      const dialog = closeTrigger.closest("dialog");
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
    }
  });

  document.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;
    if (!target.matches("[data-app-search]")) return;

    const query = target.value.trim().toLowerCase();
    const rows = document.querySelectorAll("[data-app-row]");
    let visibleCount = 0;

    rows.forEach((row) => {
      if (!(row instanceof HTMLElement)) return;
      const value = row.dataset.appSearchValue || "";
      const match = !query || value.includes(query);
      row.style.display = match ? "" : "none";
      if (match) visibleCount += 1;
    });

    const emptyState = document.querySelector("[data-app-empty]");
    if (emptyState instanceof HTMLElement) {
      emptyState.classList.toggle("hidden", visibleCount > 0);
    }
  });

  document.querySelectorAll("dialog[data-admin-dialog]").forEach((dialogNode) => {
    if (!(dialogNode instanceof HTMLDialogElement)) return;

    dialogNode.addEventListener("cancel", () => {
      dialogNode.close();
    });

    dialogNode.addEventListener("click", (event) => {
      if (event.target === dialogNode) {
        dialogNode.close();
      }
    });
  });
</script>
