---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getAdminApplications } from "../../lib/portal/admin";
import { getAdminFlash } from "../../lib/portal/admin-flash";
import { getPortalModuleConfig } from "../../lib/portal/modules";
import { withPortalBasePath } from "../../lib/portal/base-path";

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;
const moduleConfig = getPortalModuleConfig(portalModule);

if (!user || !supabase) {
  return Astro.redirect("/login");
}

const flash = getAdminFlash(Astro.url);
const applications = await getAdminApplications(supabase, portalModule);

function getDialogId(applicationId: string) {
  return `application-dialog-${applicationId}`;
}
---

<AdminLayout
  title={`Aplicaciones ${moduleConfig.name.es} | Administracion portal`}
  description={`Catalogo administrativo de aplicaciones de ${moduleConfig.name.es}`}
  userEmail={user.email ?? ""}
  activePath="/admin/aplicaciones"
  portalModule={portalModule}
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    {flash && (
      <div
        class:list={[
          "mb-6 rounded-3xl border px-4 py-3.5 text-sm sm:px-5 sm:py-4",
          flash.tone === "error"
            ? "border-red-400/30 bg-red-500/10 text-red-50"
            : "border-emerald-400/30 bg-emerald-500/10 text-emerald-50"
        ]}
      >
        {flash.message}
      </div>
    )}

    <section class="space-y-6">
      <div class="portal-panel rounded-[30px] p-5 sm:p-6">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <p class="portal-eyebrow text-[11px]">Catalogo interno</p>
            <h2 class="mt-2 text-2xl font-semibold text-white sm:text-3xl">Aplicaciones del portal</h2>
            <p class="portal-copy mt-2 hidden text-sm leading-6 sm:block">
              Vista compacta para mantener el catalogo: nombre, categoria, tier, estado y orden.
              Abri una fila para editar el detalle completo de la herramienta.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <span class="self-start rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70 sm:self-auto">
              {applications.length} aplicaciones
            </span>
            <button
              type="button"
              class="portal-action-link portal-action-link--solid w-full justify-center sm:w-auto"
              data-open-dialog="create-application-dialog"
            >
              Nueva aplicacion
            </button>
          </div>
        </div>
      </div>

      <div class="portal-panel rounded-[30px] p-0">
        <div class="px-4 pt-4 sm:px-6 sm:pt-5">
          <div class="admin-apps-toolbar">
            <label class="admin-apps-search">
              <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
              <input
                type="search"
                placeholder="Buscar por nombre, categoria, tier o estado"
                data-app-search
              />
            </label>

            <p class="portal-copy hidden text-xs sm:block sm:text-sm">
              Click en una fila para editar el detalle de la aplicacion.
            </p>
          </div>
        </div>

        <div class="overflow-x-auto">
          <div class="px-4 pb-4 lg:min-w-[1040px] sm:px-6 sm:pb-5">
            <div class="admin-apps-head">
              <span>Aplicacion</span>
              <span>Categoria</span>
              <span>Tier</span>
              <span>Estado</span>
              <span>Clientes</span>
              <span>Orden</span>
              <span class="text-right">Accion</span>
            </div>

            <div class="mt-3 space-y-3">
              {applications.map((application) => {
                const dialogId = getDialogId(application.id);
                const searchIndex = `${application.name} ${application.slug} ${application.category} ${application.accessTier} ${application.availabilityStatus}`
                  .toLowerCase()
                  .trim();

                return (
                  <>
                    <button
                      type="button"
                      class="admin-apps-row"
                      data-open-dialog={dialogId}
                      data-app-row
                      data-app-search-value={searchIndex}
                      aria-label={`Abrir detalle de ${application.name}`}
                    >
                      <span class="admin-apps-row__identity">
                        <span class="admin-apps-icon">
                          <i class:list={["fa-solid", `fa-${application.icon || "bolt"}`]} aria-hidden="true"></i>
                        </span>
                        <span class="min-w-0 text-left">
                          <strong class="block truncate text-sm text-white">{application.name}</strong>
                          <span class="portal-copy block truncate text-xs">{application.slug}</span>
                        </span>
                      </span>

                      <span class="admin-apps-row__category">{application.category}</span>
                      <span class="admin-apps-row__tier">{application.accessTier}</span>
                      <span class="admin-apps-row__status">{application.availabilityStatus}</span>
                      <span class="admin-apps-row__metric">
                        <span class="admin-apps-row__metric-label">Clientes</span>
                        <strong>{application.enabledClientsCount}</strong>
                      </span>
                      <span class="admin-apps-row__metric">
                        <span class="admin-apps-row__metric-label">Orden</span>
                        <strong>{application.sortOrder}</strong>
                      </span>
                      <span class="admin-apps-row__action text-right text-xs font-semibold uppercase tracking-[0.18em] text-[#ff8c1a]">
                        Abrir
                      </span>
                    </button>

                    <dialog id={dialogId} data-admin-dialog class="admin-apps-dialog">
                      <div class="admin-apps-dialog__panel portal-panel rounded-[32px] p-0">
                        <div class="admin-apps-dialog__header flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4 sm:px-6">
                          <div>
                            <p class="portal-eyebrow text-[11px]">Detalle de aplicacion</p>
                            <h3 class="mt-2 text-xl font-semibold text-white sm:text-2xl">{application.name}</h3>
                            <p class="portal-copy mt-1 text-sm">{application.url}</p>
                          </div>

                          <button
                            type="button"
                            class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
                            data-close-dialog
                          >
                            Cerrar
                          </button>
                        </div>

              <form action={withPortalBasePath("/api/admin/manage")} method="POST" class="flex max-h-[82vh] flex-col">
                          <input type="hidden" name="action" value="update-application" />
                          <input type="hidden" name="redirect_to" value="/admin/aplicaciones" />
                          <input type="hidden" name="application_id" value={application.id} />

                          <div class="admin-apps-dialog__body overflow-y-auto px-5 py-5 sm:px-6">
                            <div class="grid gap-5 xl:grid-cols-[270px_minmax(0,1fr)]">
                              <aside class="space-y-4">
                                <div class="rounded-[28px] border border-white/10 bg-black/20 p-4">
                                  <p class="portal-copy text-xs uppercase tracking-[0.14em]">Resumen</p>
                                  <div class="mt-4 flex items-center gap-3">
                                    <span class="admin-apps-icon admin-apps-icon--large">
                                      <i class:list={["fa-solid", `fa-${application.icon || "bolt"}`]} aria-hidden="true"></i>
                                    </span>
                                    <div class="min-w-0">
                                      <strong class="block truncate text-white">{application.name}</strong>
                                      <p class="portal-copy truncate text-sm">{application.category}</p>
                                    </div>
                                  </div>

                                  <div class="mt-4 grid grid-cols-2 gap-3">
                                    <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                                      <p class="portal-copy text-[11px] uppercase tracking-[0.14em]">Tier</p>
                                      <strong class="mt-2 block text-base text-white">{application.accessTier}</strong>
                                    </div>
                                    <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                                      <p class="portal-copy text-[11px] uppercase tracking-[0.14em]">Clientes</p>
                                      <strong class="mt-2 block text-base text-white">{application.enabledClientsCount}</strong>
                                    </div>
                                  </div>
                                </div>
                              </aside>

                              <div class="space-y-5">
                                <div class="rounded-[28px] border border-white/10 bg-black/20 p-4 sm:p-5">
                                  <div>
                                    <p class="portal-copy text-xs uppercase tracking-[0.14em]">Datos base</p>
                                    <p class="portal-copy mt-1 text-sm">Identidad, ruta, descripcion y clasificacion.</p>
                                  </div>

                                  <div class="mt-4 grid gap-4 lg:grid-cols-2">
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="name" value={application.name} required />
                                    </label>
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Slug</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="slug" value={application.slug} required />
                                    </label>
                                  </div>

                                  <label class="mt-4 block">
                                    <span class="mb-2 block text-sm font-medium text-white/80">URL</span>
                                    <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="url" value={application.url} required />
                                  </label>

                                  <label class="mt-4 block">
                                    <span class="mb-2 block text-sm font-medium text-white/80">Descripcion</span>
                                    <textarea class="portal-input min-h-24 w-full rounded-2xl px-4 py-3" name="description">{application.description ?? ""}</textarea>
                                  </label>
                                </div>

                                <div class="rounded-[28px] border border-white/10 bg-black/20 p-4 sm:p-5">
                                  <div class="grid gap-4 lg:grid-cols-3">
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Icono</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="icon" value={application.icon ?? ""} />
                                    </label>
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Categoria</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="category" value={application.category} />
                                    </label>
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Orden</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="number" name="sort_order" value={application.sortOrder} />
                                    </label>
                                  </div>

                                  <div class="mt-4 grid gap-4 lg:grid-cols-3">
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Tags</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="area_tags" value={application.areaTags.join(", ")} />
                                    </label>
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Tier</span>
                                      <select class="portal-input w-full rounded-2xl px-4 py-3" name="access_tier">
                                        <option value="included" selected={application.accessTier === "included"}>Included</option>
                                        <option value="premium" selected={application.accessTier === "premium"}>Premium</option>
                                        <option value="featured" selected={application.accessTier === "featured"}>Featured</option>
                                        <option value="new" selected={application.accessTier === "new"}>New</option>
                                      </select>
                                    </label>
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Estado</span>
                                      <select class="portal-input w-full rounded-2xl px-4 py-3" name="availability_status">
                                        <option value="available" selected={application.availabilityStatus === "available"}>Available</option>
                                        <option value="coming_soon" selected={application.availabilityStatus === "coming_soon"}>Coming soon</option>
                                        <option value="disabled" selected={application.availabilityStatus === "disabled"}>Disabled</option>
                                      </select>
                                    </label>
                                  </div>

                                  <div class="mt-4 grid gap-4 lg:grid-cols-[1fr_auto]">
                                    <label class="block">
                                      <span class="mb-2 block text-sm font-medium text-white/80">Badge</span>
                                      <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="badge_label" value={application.badgeLabel ?? ""} />
                                    </label>
                                    <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
                                      <input type="hidden" name="is_active" value="false" />
                                      <input type="checkbox" name="is_active" value="true" checked={application.isActive} class="h-4 w-4" />
                                      Aplicacion activa
                                    </label>
                                  </div>

                                  <div class="mt-4 rounded-[24px] border border-red-400/25 bg-red-500/10 px-4 py-3 text-sm text-red-50/90">
                                    Esta accion quita la aplicacion de la lista operativa y desactiva tambien sus accesos asociados.
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div class="admin-apps-dialog__footer flex flex-wrap items-center justify-between gap-3 border-t border-white/10 px-5 py-4 sm:px-6">
                            <button
                              type="submit"
                              name="intent"
                              value="delete-application"
                              class="portal-action-link border-red-400/25 bg-red-500/10 text-red-50 hover:border-red-300/30 hover:bg-red-500/15"
                              data-confirm-submit="Vas a quitar esta aplicacion de la lista y desactivar sus accesos asociados. Esta accion no se puede deshacer. ¿Deseas continuar?"
                            >
                              Eliminar aplicacion
                            </button>

                            <div class="flex flex-wrap items-center justify-end gap-3">
                              <button type="button" class="portal-action-link" data-close-dialog>
                                Cancelar
                              </button>
                              <button type="submit" class="portal-action-link portal-action-link--solid">
                                Guardar cambios
                              </button>
                            </div>
                          </div>
                        </form>
                      </div>
                    </dialog>
                  </>
                );
              })}
            </div>

            <div class="portal-empty-state mt-4 hidden rounded-[24px] px-4 py-5 text-sm" data-app-empty>
              No encontramos aplicaciones con ese criterio de busqueda.
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <dialog id="create-application-dialog" data-admin-dialog class="admin-apps-dialog admin-apps-dialog--compact">
    <div class="admin-apps-dialog__panel portal-panel rounded-[32px] p-0">
      <div class="admin-apps-dialog__header flex items-start justify-between gap-4 border-b border-white/10 px-5 py-4 sm:px-6">
        <div>
          <p class="portal-eyebrow text-[11px]">Alta de herramienta</p>
          <h3 class="mt-2 text-2xl font-semibold text-white">Nueva aplicacion</h3>
          <p class="portal-copy mt-1 text-sm">Agrega una herramienta al catalogo para habilitarla por cliente.</p>
        </div>

        <button
          type="button"
          class="rounded-full border border-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white/70 transition hover:border-white/20 hover:text-white"
          data-close-dialog
        >
          Cerrar
        </button>
      </div>

              <form action={withPortalBasePath("/api/admin/manage")} method="POST" class="flex max-h-[82vh] flex-col">
        <input type="hidden" name="action" value="create-application" />
        <input type="hidden" name="redirect_to" value="/admin/aplicaciones" />

        <div class="admin-apps-dialog__body overflow-y-auto px-5 py-5 sm:px-6">
          <div class="space-y-4 rounded-[28px] border border-white/10 bg-black/20 p-4 sm:p-5">
            <div class="grid gap-4 lg:grid-cols-2">
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Nombre</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="name" required />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Slug</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="slug" required />
              </label>
            </div>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">URL</span>
              <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="url" placeholder="/clientes/aplicaciones/nueva-herramienta" required />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-white/80">Descripcion</span>
              <textarea class="portal-input min-h-24 w-full rounded-2xl px-4 py-3" name="description"></textarea>
            </label>

            <div class="grid gap-4 lg:grid-cols-3">
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Icono</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="icon" placeholder="clock" />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Categoria</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="category" value="General" />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Orden</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="number" name="sort_order" value="0" />
              </label>
            </div>

            <div class="grid gap-4 lg:grid-cols-3">
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Tags</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="area_tags" placeholder="Time Tracking, Reportes" />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Tier</span>
                <select class="portal-input w-full rounded-2xl px-4 py-3" name="access_tier">
                  <option value="included">Included</option>
                  <option value="premium">Premium</option>
                  <option value="featured">Featured</option>
                  <option value="new">New</option>
                </select>
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Estado</span>
                <select class="portal-input w-full rounded-2xl px-4 py-3" name="availability_status">
                  <option value="available">Available</option>
                  <option value="coming_soon">Coming soon</option>
                  <option value="disabled">Disabled</option>
                </select>
              </label>
            </div>

            <div class="grid gap-4 lg:grid-cols-[1fr_auto]">
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-white/80">Badge</span>
                <input class="portal-input w-full rounded-2xl px-4 py-3" type="text" name="badge_label" placeholder="Operativa" />
              </label>
              <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">
                <input type="hidden" name="is_active" value="false" />
                <input type="checkbox" name="is_active" value="true" checked class="h-4 w-4" />
                Aplicacion activa
              </label>
            </div>
          </div>
        </div>

        <div class="admin-apps-dialog__footer flex flex-wrap items-center justify-end gap-3 border-t border-white/10 px-5 py-4 sm:px-6">
          <button type="button" class="portal-action-link" data-close-dialog>
            Cancelar
          </button>
          <button type="submit" class="portal-action-link portal-action-link--solid">
            Crear aplicacion
          </button>
        </div>
      </form>
    </div>
  </dialog>
</AdminLayout>

<style>
  .admin-apps-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .admin-apps-search {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: min(100%, 440px);
    padding: 0.9rem 1rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .admin-apps-search i {
    color: rgba(255, 255, 255, 0.5);
  }

  .admin-apps-search input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font: inherit;
  }

  .admin-apps-search input::placeholder {
    color: rgba(255, 255, 255, 0.42);
  }

  .admin-apps-head,
  .admin-apps-row {
    display: grid;
    grid-template-columns: minmax(280px, 2.1fr) minmax(130px, 1fr) minmax(110px, 0.8fr) minmax(120px, 0.9fr) minmax(90px, 0.7fr) minmax(90px, 0.6fr) minmax(80px, 0.55fr);
    gap: 0.75rem;
    align-items: center;
  }

  .admin-apps-head {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0 1rem 0.9rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .admin-apps-row {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.35rem;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.95rem 1rem;
    text-align: left;
    transition: border-color 180ms ease, background-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .admin-apps-row:hover {
    border-color: rgba(239, 124, 14, 0.36);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-1px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
  }

  .admin-apps-row:focus-visible {
    outline: 2px solid rgba(255, 140, 26, 0.7);
    outline-offset: 3px;
  }

  .admin-apps-row__identity {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.8rem;
  }

  .admin-apps-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .admin-apps-icon--large {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 1.2rem;
    font-size: 1.05rem;
  }

  .admin-apps-row__category,
  .admin-apps-row__tier,
  .admin-apps-row__status,
  .admin-apps-row__metric strong {
    color: #fff;
    font-size: 0.92rem;
  }

  .admin-apps-row__metric {
    display: grid;
    gap: 0.15rem;
  }

  .admin-apps-row__metric-label {
    display: none;
    font-size: 0.68rem;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  .admin-apps-dialog {
    width: min(1100px, calc(100vw - 2rem));
    max-width: 1100px;
    border: 0;
    background: transparent;
    padding: 0;
    color: inherit;
  }

