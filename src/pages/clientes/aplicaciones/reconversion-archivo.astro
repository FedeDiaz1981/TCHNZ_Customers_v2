---
import ReconversionPanel from "../../../components/portal/ReconversionPanel.astro";
import { getCustomerLocale } from "../../../lib/i18n/customers";
import { getSectionHrefForPath } from "../../../lib/portal/hosts";
import { moduleRequiresAuth } from "../../../lib/portal/modules";

const user = Astro.locals.user;
const profile = Astro.locals.profile;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;

if (!supabase) {
  return Astro.redirect(getSectionHrefForPath(Astro.url, "/login"));
}

const requiresAuth = moduleRequiresAuth(portalModule);
const userEmail = requiresAuth ? profile?.fullName ?? user?.email ?? "" : "";
const locale = getCustomerLocale(Astro.url, Astro.cookies);
const backToAppsHref = getSectionHrefForPath(Astro.url, "/clientes/aplicaciones");
const manualHref = getSectionHrefForPath(Astro.url, "/clientes/aplicaciones/manual-usuario");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{locale === "en" ? "Time Clock Conversion | Technized Clients" : "Reconversion Fichadas | Technized Clientes"}</title>
    <meta
      name="description"
      content={locale === "en"
        ? "Private application for converting time clock operational records."
        : "Aplicacion privada para reconvertir fichadas operativas."}
    />
    <link rel="icon" href="/customers/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --rec-bg: #09070d;
        --rec-bg-soft: rgba(255, 255, 255, 0.03);
        --rec-panel: rgba(24, 16, 30, 0.74);
        --rec-panel-strong: rgba(20, 14, 26, 0.86);
        --rec-ink: #f4f1f8;
        --rec-muted: #9f97ab;
        --rec-navy: #f4f1f8;
        --rec-blue: #f49a2f;
        --rec-cyan: #d97b1b;
        --rec-green: #86efac;
        --rec-border: rgba(255, 255, 255, 0.08);
        --rec-shadow: 0 12px 50px rgba(0, 0, 0, 0.35);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
      }

      html {
        background: #09070d;
      }

      body.rec-app-body {
        min-height: 100vh;
        min-height: 100dvh;
        margin: 0;
        font-family: "Inter", system-ui, sans-serif;
        color: var(--rec-ink);
        background-color: #09070d;
        background:
          radial-gradient(60% 80% at 50% 18%, rgba(92, 36, 15, 0.22), transparent 55%),
          radial-gradient(35% 30% at 50% 48%, rgba(244, 154, 47, 0.1), transparent 60%),
          linear-gradient(180deg, #140d1d 0%, #09070d 100%);
      }

      body.rec-app-body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.02) 0 1px, transparent 1px 100%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.01) 0 1px, transparent 1px 100%);
        background-size: 100px 100px;
        opacity: 0.08;
        mix-blend-mode: soft-light;
      }

      .rec-page {
        position: relative;
        z-index: 1;
        max-width: 1180px;
        margin: 0 auto;
        padding: 36px 24px 44px;
      }

      .rec-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        margin-bottom: 38px;
        padding-bottom: 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .rec-back-button {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        min-height: 52px;
        padding: 0 18px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
        color: #d8d1e1;
        text-decoration: none;
        font-weight: 700;
      }

      .rec-back-button:hover {
        border-color: rgba(244, 154, 47, 0.32);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.03));
      }

      .rec-back-button:focus-visible,
      .rec-btn:focus-visible,
      .rec-file-input:focus-visible {
        outline: 2px solid rgba(239, 124, 14, 0.8);
        outline-offset: 3px;
      }

      .rec-client-mail {
        font-size: 15px;
        font-weight: 700;
        color: #efe9f7;
        text-align: right;
        word-break: break-word;
      }

      .rec-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 28px;
      }

      .rec-hero-title-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
      }

      .rec-kicker {
        margin: 0 0 8px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--rec-blue);
      }

      .rec-page h1 {
        margin: 0;
        font-size: 48px;
        line-height: 1.04;
        letter-spacing: -0.04em;
        color: var(--rec-navy);
      }

      .rec-subtitle {
        max-width: 720px;
        margin: 14px 0 0;
        color: var(--rec-muted);
        font-size: 16px;
        line-height: 1.65;
      }

      .rec-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: linear-gradient(180deg, rgba(28, 20, 34, 0.88), rgba(18, 12, 24, 0.84));
        padding: 12px 18px;
        box-shadow: var(--rec-shadow);
        color: var(--rec-muted);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .rec-grid {
        display: grid;
        grid-template-columns: minmax(300px, 0.92fr) minmax(0, 1.3fr);
        gap: 26px;
      }

      .rec-column {
        display: flex;
        flex-direction: column;
        gap: 22px;
      }

      .rec-card {
        border-radius: 24px;
        border: 1px solid var(--rec-border);
        background:
          radial-gradient(50% 120% at 25% 0%, rgba(244, 154, 47, 0.1), transparent 52%),
          linear-gradient(180deg, rgba(28, 20, 34, 0.88), rgba(18, 12, 24, 0.84));
        box-shadow: var(--rec-shadow);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .rec-card--control,
      .rec-card--metrics {
        padding: 28px;
      }

      .rec-card--log {
        padding: 24px;
        min-height: 320px;
      }

      .rec-card--footer {
        padding: 22px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
      }

      .rec-card-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        color: var(--rec-navy);
      }

      .rec-card-head h2 {
        margin: 0;
        font-size: 18px;
      }

      .rec-control-stack {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .rec-file-input {
        width: 100%;
        border-radius: 16px;
        border: 1px solid var(--rec-border);
        background: rgba(255, 255, 255, 0.03);
        color: #d7d0e2;
        padding: 10px;
        font-size: 14px;
      }

      .rec-file-input::file-selector-button {
        margin-right: 12px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 0;
        background: linear-gradient(180deg, #f8a63c, #eb7f18);
        color: #1a0f06;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.05em;
        cursor: pointer;
      }

      .rec-button-row {
        display: flex;
        gap: 10px;
      }

      .rec-btn {
        appearance: none;
        border: 0;
        border-radius: 16px;
        min-height: 52px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 0 18px;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease,
          border-color 0.18s ease, color 0.18s ease;
        text-decoration: none;
      }

      .rec-btn:hover:not(:disabled) {
        transform: translateY(-1px);
      }

      .rec-btn:disabled {
        cursor: not-allowed;
        opacity: 0.5;
        transform: none;
      }

      .rec-btn--primary {
        flex: 1 1 auto;
        background: linear-gradient(180deg, #f8a63c, #eb7f18);
        color: #fff8f0;
        box-shadow: 0 12px 28px rgba(233, 126, 23, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.22);
      }

      .rec-btn--secondary {
        width: 56px;
        flex: 0 0 56px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        color: #cfc9d8;
      }

      .rec-btn--manual {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.07);
        background: rgba(255, 255, 255, 0.03);
        color: #ddd6e6;
      }

      .rec-btn--manual:hover:not(:disabled) {
        border-color: rgba(244, 154, 47, 0.32);
        background: rgba(255, 255, 255, 0.05);
        color: #f4f1f8;
      }

      .rec-btn--download {
        background: linear-gradient(180deg, #f8a63c, #eb7f18);
        color: #fff8f0;
        min-width: 220px;
        box-shadow: 0 12px 28px rgba(233, 126, 23, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.22);
      }

      .rec-log-panel {
        border-radius: 18px;
        border: 1px solid var(--rec-border);
        background: linear-gradient(180deg, rgba(28, 20, 34, 0.86), rgba(18, 12, 24, 0.82));
        padding: 16px;
        min-height: 228px;
        max-height: 360px;
        overflow: auto;
        font-family: "Consolas", "SFMono-Regular", monospace;
        font-size: 12px;
        line-height: 1.65;
      }

      .rec-log-empty {
        color: var(--rec-muted);
      }

      .rec-log-row {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        color: #e7e0ef;
      }

      .rec-log-row + .rec-log-row {
        margin-top: 8px;
      }

      .rec-log-row--success {
        color: #86efac;
      }

      .rec-log-row--error {
        color: #ff8f8f;
      }

      .rec-log-time {
        color: var(--rec-muted);
        white-space: nowrap;
      }

      .rec-metrics-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 20px;
      }

      .rec-metrics-kicker {
        margin: 0 0 6px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--rec-blue);
      }

      .rec-metrics-head h2 {
        margin: 0;
        font-size: 28px;
        line-height: 1.05;
        color: var(--rec-navy);
      }

      .rec-time {
        font-family: "Consolas", "SFMono-Regular", monospace;
        color: var(--rec-muted);
        font-size: 13px;
      }

      .rec-progress-track {
        width: 100%;
        height: 12px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        margin-bottom: 22px;
      }

      .rec-progress-fill {
        height: 100%;
        width: 0;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--rec-blue), var(--rec-cyan));
        transition: width 0.3s ease;
      }

      .rec-metrics-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .rec-metric-card {
        border-radius: 18px;
        border: 1px solid var(--rec-border);
        background: linear-gradient(180deg, rgba(28, 20, 34, 0.86), rgba(18, 12, 24, 0.82));
        padding: 16px;
      }

      .rec-metric-card strong {
        display: block;
        margin-top: 8px;
        font-size: 30px;
        line-height: 1;
        color: var(--rec-navy);
      }

      .rec-metric-card.is-success {
        border-color: rgba(134, 239, 172, 0.24);
        background: rgba(31, 109, 56, 0.14);
      }

      .rec-metric-card.is-success strong,
      .rec-metric-card.is-success .rec-metric-label {
        color: #86efac;
      }

      .rec-metric-card.is-danger {
        border-color: rgba(255, 143, 143, 0.24);
        background: rgba(180, 35, 24, 0.14);
      }

      .rec-metric-card.is-danger strong,
      .rec-metric-card.is-danger .rec-metric-label {
        color: #ff8f8f;
      }

      .rec-metric-label {
        display: block;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--rec-muted);
      }

      .rec-footer-copy {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        color: var(--rec-muted);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .rec-divider {
        width: 1px;
        height: 14px;
        background: rgba(255, 255, 255, 0.12);
      }

      .rec-footer-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .rec-ready-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.07);
        background: rgba(255, 255, 255, 0.03);
        color: #cfc9d8;
        min-height: 42px;
        padding: 0 16px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .rec-icon-svg {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
      }

      .rec-icon-svg--hero {
        width: 32px;
        height: 32px;
        color: var(--rec-blue);
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--rec-cyan);
        box-shadow: 0 0 0 4px rgba(239, 124, 14, 0.16);
      }

      .dot.ok {
        background: #1f6d38;
        box-shadow: 0 0 0 4px rgba(31, 109, 56, 0.14);
      }

      .dot.bad {
        background: #b42318;
        box-shadow: 0 0 0 4px rgba(180, 35, 24, 0.14);
      }

      @media (max-width: 960px) {
        .rec-grid {
          grid-template-columns: 1fr;
        }

        .rec-metrics-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .rec-card--footer {
          flex-direction: column;
          align-items: flex-start;
        }

        .rec-footer-actions {
          justify-content: flex-start;
        }
      }

      @media (max-width: 720px) {
        .rec-page {
          padding: 24px 14px 28px;
        }

        .rec-topbar,
        .rec-hero {
          flex-direction: column;
          align-items: stretch;
        }

        .rec-page h1 {
          font-size: 36px;
        }

        .rec-subtitle {
          font-size: 14px;
        }

        .rec-button-row,
        .rec-footer-actions {
          flex-direction: column;
          align-items: stretch;
        }

        .rec-btn--secondary,
        .rec-btn--download {
          width: 100%;
          min-width: 0;
          flex: 1 1 auto;
        }

        .rec-metrics-grid {
          grid-template-columns: 1fr;
        }

        .rec-card--control,
        .rec-card--metrics,
        .rec-card--log,
        .rec-card--footer {
          padding: 18px;
        }
      }
    </style>
  </head>
  <body class="rec-app-body">
    <ReconversionPanel
      userEmail={userEmail}
      locale={locale}
      backToAppsHref={backToAppsHref}
      manualHref={manualHref}
    />
  </body>
</html>
