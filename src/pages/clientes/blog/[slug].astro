---
import PortalLayout from "../../../layouts/PortalLayout.astro";
import {
  getCustomerIntlLocale,
  getCustomerLocale,
  getCustomerUi
} from "../../../lib/i18n/customers";
import {
  getCurrentPortalClient,
  getPortalBlogPostBySlug
} from "../../../lib/portal/client-access";
import { getSectionHrefForPath } from "../../../lib/portal/hosts";
import {
  getModuleContentSection,
  moduleRequiresAuth
} from "../../../lib/portal/modules";

const user = Astro.locals.user;
const profile = Astro.locals.profile;
const supabase = Astro.locals.supabase;
const portalModule = Astro.locals.portalModule;

if (!supabase) {
  return Astro.redirect(getSectionHrefForPath(Astro.url, "/login"));
}

const slug = Astro.params.slug ?? "";
const locale = getCustomerLocale(Astro.url, Astro.cookies);
const ui = getCustomerUi(locale).blogDetail;
const requiresAuth = moduleRequiresAuth(portalModule);
const contentSection = getModuleContentSection(portalModule) ?? "blog";
const currentClient =
  requiresAuth && user ? await getCurrentPortalClient(supabase, user.id, portalModule) : null;
const post = slug ? await getPortalBlogPostBySlug(supabase, portalModule, slug, contentSection) : null;
const blogListHref = getSectionHrefForPath(Astro.url, "/clientes/blog");
const userDisplayName = profile?.fullName ?? user?.email ?? "";

if (!post) {
  return Astro.redirect(getSectionHrefForPath(Astro.url, "/clientes/blog"));
}

function formatDateLabel(value: string | null) {
  const source = value ?? post.createdAt;

  return new Intl.DateTimeFormat(getCustomerIntlLocale(locale), {
    day: "2-digit",
    month: "long",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  }).format(new Date(source));
}
---

<PortalLayout
  title={`${post.title} | ${ui.titleSuffix}`}
  description={post.summary ?? ui.descriptionFallback}
  userEmail={userDisplayName}
  activePath="/clientes/blog"
  clientName={currentClient?.name ?? ""}
  clientLogoUrl={currentClient?.logoUrl ?? ""}
  locale={locale}
  portalModule={portalModule}
>
  <section class="portal-panel rounded-[32px] p-6 md:p-8">
    <div class="portal-blog-article__back">
      <a href={blogListHref} class="portal-action-link">
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        {ui.backToBlog}
      </a>
    </div>

    <article class="portal-blog-article mt-6">
      {post.coverImageUrl ? (
        <div class="portal-blog-article__cover">
          <img src={post.coverImageUrl} alt={post.title} />
        </div>
      ) : null}

      <header class="portal-blog-article__header">
        <p class="portal-eyebrow">{ui.eyebrow}</p>
        <h1>{post.title}</h1>
        <div class="portal-blog-article__meta">
          <span>{formatDateLabel(post.publishedAt)}</span>
          <span class="portal-blog-article__dot"></span>
          <span>{post.authorName}</span>
          {post.isFeatured && (
            <>
              <span class="portal-blog-article__dot"></span>
              <span>{ui.featured}</span>
            </>
          )}
        </div>
        {post.summary && <p class="portal-blog-article__summary">{post.summary}</p>}
      </header>

      <div class="portal-blog-article__tags">
        {post.tags.map((tag) => (
          <span class="portal-tag">{tag}</span>
        ))}
      </div>

      <div class="portal-blog-article__content">
        {post.content}
      </div>
    </article>
  </section>

  <p class="mt-8 text-center text-xs font-medium tracking-[0.18em] text-white/45">
    {ui.footer}
  </p>

  <style>
    .portal-blog-article {
      display: grid;
      gap: 1.5rem;
    }

    .portal-blog-article__back {
      display: flex;
      justify-content: flex-start;
    }

    .portal-blog-article__cover {
      overflow: hidden;
      border-radius: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      max-height: 460px;
    }

    .portal-blog-article__cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .portal-blog-article__header {
      display: grid;
      gap: 1rem;
    }

    .portal-blog-article__header h1 {
      margin: 0;
      font-size: clamp(2.3rem, 5vw, 4.6rem);
      line-height: 0.98;
      color: #fff;
      max-width: 14ch;
    }

    .portal-blog-article__meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.55rem;
      font-size: 0.84rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.6);
    }

    .portal-blog-article__dot {
      width: 0.32rem;
      height: 0.32rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.3);
    }

    .portal-blog-article__summary {
      max-width: 62rem;
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.76);
    }

    .portal-blog-article__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }

    .portal-blog-article__content {
      max-width: 70rem;
      padding: 1.5rem;
      border-radius: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.04);
      color: rgba(255, 255, 255, 0.88);
      font-size: 1rem;
      line-height: 1.95;
      white-space: pre-wrap;
    }
  </style>
</PortalLayout>
